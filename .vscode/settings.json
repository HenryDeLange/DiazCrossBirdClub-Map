{
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.codeActionsOnSave": [
        "source.addMissingImports",
        "source.organizeImports"
    ],
    "files.exclude": {
        "**/.stylelintcache": true,
        "**/node_modules": true,
    },
    "files.watcherExclude": {
        "**/dist": true
    },
    "cSpell.words": [
        "Addo",
        "Assegaai",
        "Bakanas",
        "Boknes",
        "DCBC",
        "Diepkloof",
        "Ghio",
        "iNat",
        "Kariega",
        "Kasouga",
        "latlng",
        "locatecontrol",
        "Ngciyo",
        "stylelint",
        "tailwindcss"
    ]
}